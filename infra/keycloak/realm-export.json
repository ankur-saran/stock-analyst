{
  "realm": "stock-analyst",
  "displayName": "Stock Analyst AI",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 900,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "sslRequired": "external",
  "roles": {
    "realm": [
      {
        "name": "viewer",
        "description": "Read-only access to analysis outputs",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "analyst",
        "description": "Can create and manage coverages",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "senior_analyst",
        "description": "Can approve and publish analysis",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "admin",
        "description": "Full platform administration",
        "composite": false,
        "clientRole": false
      }
    ],
    "client": {}
  },
  "clients": [
    {
      "clientId": "stock-analyst-api",
      "name": "Stock Analyst API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "clientAuthenticatorType": "client-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false,
      "consentRequired": false,
      "fullScopeAllowed": true,
      "redirectUris": [],
      "webOrigins": []
    },
    {
      "clientId": "stock-analyst-web",
      "name": "Stock Analyst Web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "clientAuthenticatorType": "client-secret",
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "consentRequired": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "https://*.stock-analyst.internal/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "https://*.stock-analyst.internal"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenant_id",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
