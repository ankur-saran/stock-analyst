# =============================================================================
# PostgreSQL
# =============================================================================
# Database username
POSTGRES_USER=stockanalyst
# Database password — change before deploying
POSTGRES_PASSWORD=changeme
# Database name
POSTGRES_DB=stockanalyst
# Hostname of the Postgres server (use "localhost" outside Docker, "postgres" inside)
POSTGRES_HOST=localhost
# Postgres port (default: 5432)
POSTGRES_PORT=5432

# =============================================================================
# Redis
# =============================================================================
# Full Redis connection URL used by Celery workers and caching layers
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Qdrant (vector store)
# =============================================================================
# Hostname of the Qdrant server (use "localhost" outside Docker, "qdrant" inside)
QDRANT_HOST=localhost
# Qdrant REST/gRPC port (default: 6333)
QDRANT_PORT=6333

# =============================================================================
# MinIO (object storage)
# =============================================================================
# MinIO root (admin) username
MINIO_ROOT_USER=minioadmin
# MinIO root (admin) password — change before deploying
MINIO_ROOT_PASSWORD=changeme
# MinIO S3-compatible endpoint (include port; no trailing slash)
MINIO_ENDPOINT=http://localhost:9000

# =============================================================================
# Keycloak (identity & access management)
# =============================================================================
# Base URL of the Keycloak server
KEYCLOAK_URL=http://localhost:8080
# Keycloak realm name (must match realm-export.json)
KEYCLOAK_REALM=stockanalyst
# OAuth2 client ID registered in the realm
KEYCLOAK_CLIENT_ID=stockanalyst-api
# OAuth2 client secret — copy from Keycloak admin console after first boot
KEYCLOAK_CLIENT_SECRET=changeme
# Keycloak admin username (used only by docker-compose to bootstrap the server)
KEYCLOAK_ADMIN=admin
# Keycloak admin password — change before deploying
KEYCLOAK_ADMIN_PASSWORD=changeme

# =============================================================================
# LLM providers
# =============================================================================
# Anthropic API key — obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI API key — obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# =============================================================================
# LiteLLM proxy
# =============================================================================
# Base URL of the LiteLLM proxy (all agent LLM calls route through here)
LITELLM_URL=http://localhost:4000

# =============================================================================
# Ollama (local LLM runtime)
# =============================================================================
# Base URL of the Ollama server (use "localhost" outside Docker, "ollama" inside)
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# LangSmith (tracing & evaluation)
# =============================================================================
# LangSmith API key — obtain from https://smith.langchain.com
LANGSMITH_API_KEY=ls__...
# LangSmith project name — traces will appear under this project
LANGSMITH_PROJECT=stock-analyst-dev

# =============================================================================
# Tavily (web search tool used by research agents)
# =============================================================================
# Tavily API key — obtain from https://app.tavily.com
TAVILY_API_KEY=tvly-...

# =============================================================================
# FastAPI application
# =============================================================================
# Secret key used to sign session cookies and JWT tokens — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-secret
# Runtime environment: development | staging | production
ENVIRONMENT=development
